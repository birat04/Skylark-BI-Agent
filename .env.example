# Postgres (Neon recommended — serverless, pairs with Vercel deploys)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# monday.com API token.
# For the app's normal read-only sync/query runtime, a read-scoped token is enough.
# For the one-time `npm run import:monday` setup script, this must be a WRITE-scoped
# token (it creates boards/columns/items) — see doc/phase.md Phase 0.
MONDAY_API_TOKEN=""

# NOTE: board IDs and column IDs are NOT env vars — they're generated automatically
# by `npm run import:monday` into lib/monday/board-config.json (no secrets in that
# file, safe to commit). Run the import script once before syncing/querying.

# monday.com GraphQL pagination page size. 100 is monday.com's own typical max and
# what caused the complexity-budget rate limit during the initial import (see
# doc/decision-log.md) — lower this if you hit that again on a smaller plan.
MONDAY_PAGE_SIZE="100"

# Max /api/sync triggers allowed per rolling 24h window (tracked via the sync_runs
# table, so it holds across serverless instances — see doc/rule.md §6).
MONDAY_SYNC_RATE_LIMIT="100"

# If the last sync is older than this many days, every chat answer surfaces a
# staleness caveat instead of just silently stating an old timestamp.
MONDAY_DATA_STALE_AFTER_DAYS="3"

# Groq API key — https://console.groq.com
GROQ_API_KEY=""

# Groq model for chat/tool-calling. qwen/qwen3.6-27b is reliable for tool calls on Groq.
GROQ_MODEL="qwen/qwen3.6-27b"
